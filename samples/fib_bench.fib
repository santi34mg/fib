import std::libc

fn fib(n: @int4) @int4;

fn fib(n: @int4) @int4 {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

fn main() @int4 {
    libc::printf("Fibonacci benchmark (recursive, no memoization)\n")
    libc::printf("-----------------------------------------------\n")
    for (i: @int4 = 0; i <= 50; i += 1) {
        result: @int4 = fib(i)
        libc::printf("fib(%d) = %d\n", i, result)
    }
    return 0
}
