import std::libc

const type Node = struct {
    sint32 data,
    *Node next,
}

fn push(*Node head, sint32 val) *Node {
    var *Node node = libc::malloc(16 as uint64) as *Node
    node.* = Node { data: val, next: head }
    return node
}

fn list_length(*Node head) sint32 {
    var sint32 count = 0
    var *Node cur = head
    for (;;) {
        if cur as uint64 == 0 as uint64 {
            break
        }
        count += 1
        cur = cur.*.next
    }
    return count
}

fn print_list(*Node head) void {
    var *Node cur = head
    for (;;) {
        if cur as uint64 == 0 as uint64 {
            break
        }
        libc::printf("%d -> ", cur.*.data)
        cur = cur.*.next
    }
    libc::printf("null\n")
}

fn free_list(*Node head) void {
    var *Node cur = head
    for (;;) {
        if cur as uint64 == 0 as uint64 {
            break
        }
        var *Node next = cur.*.next
        libc::free(cur as *void)
        cur = next
    }
}

fn main() sint32 {
    var *Node head
    defer free_list(head)

    head = push(head, 30)
    head = push(head, 20)
    head = push(head, 10)

    libc::printf("List:   ")
    print_list(head)
    libc::printf("Length: %d\n", list_length(head))

    return 0
}
