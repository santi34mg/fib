import std::libc

type Color enum {
    Red,
    Green,
    Blue,
}

fn describe(c: Color) void {
    switch (c) {
        when .Red { libc::printf("red\n") }
        when .Green { libc::printf("green\n") }
        when .Blue { libc::printf("blue\n") }
    }
}

fn main() int4 {
    describe(Color.Red)
    describe(Color.Green)
    describe(Color.Blue)
    return 0
}
